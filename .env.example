# -----------------------------------------------------------------------------
# Deployment Mode
# -----------------------------------------------------------------------------
# Use "bundled-db" to start the built-in PostgreSQL container in docker compose.
# Leave empty when using an external PostgreSQL instance.
COMPOSE_PROFILES=bundled-db

# -----------------------------------------------------------------------------
# App (HTTP / Runtime)
# -----------------------------------------------------------------------------
PORT=3000
CODEX_MASTER_KEY=change-me-in-production-use-32-chars-min
JWT_SECRET=change-me-in-production-jwt-secret
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=30
MAX_LOGIN_FAILURES=5
LOGIN_LOCK_MINUTES=15

# -----------------------------------------------------------------------------
# Bootstrap Admin (first-time seed)
# -----------------------------------------------------------------------------
INITIAL_ADMIN_USERNAME=codex
INITIAL_ADMIN_PASSWORD=codex
INITIAL_ADMIN_DISPLAY_NAME=Codex Admin

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# RUST_LOG controls Rust tracing level filters.
# Examples:
#   backend=info,tower_http=info   (recommended default)
#   backend=debug,tower_http=debug (more verbose)
#   debug                          (very verbose, all crates)
RUST_LOG=backend=info,tower_http=info

# -----------------------------------------------------------------------------
# Bundled PostgreSQL (used only when COMPOSE_PROFILES=bundled-db)
# -----------------------------------------------------------------------------
POSTGRES_USER=codexfleet
POSTGRES_PASSWORD=codexfleet
POSTGRES_DB=codexfleet

# -----------------------------------------------------------------------------
# Database URL
# -----------------------------------------------------------------------------
# Default points to the bundled PostgreSQL service in docker compose.
# Override this when using an external PostgreSQL.
DATABASE_URL=postgres://codexfleet:codexfleet@postgres:5432/codexfleet
