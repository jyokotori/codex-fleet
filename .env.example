# -----------------------------------------------------------------------------
# App (HTTP / Runtime)
# -----------------------------------------------------------------------------
PORT=3000
CODEX_MASTER_KEY=change-me-in-production-use-32-chars-min
JWT_SECRET=change-me-in-production-jwt-secret
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=30
MAX_LOGIN_FAILURES=5
LOGIN_LOCK_MINUTES=15

# -----------------------------------------------------------------------------
# Bootstrap Admin (first-time seed)
# -----------------------------------------------------------------------------
INITIAL_ADMIN_USERNAME=codex
INITIAL_ADMIN_PASSWORD=codex
INITIAL_ADMIN_DISPLAY_NAME=Codex Admin

# -----------------------------------------------------------------------------
# External API (header-secret auth for programmatic access)
# -----------------------------------------------------------------------------
EXTERNAL_API_HEADER=X-Agent-Secret
EXTERNAL_API_SECRET=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
RUST_LOG=backend=info,runtime_agent=info,iam=info,config_center=info,notification_center=info,shared_kernel=info,tower_http=info

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=codexfleet
POSTGRES_PASSWORD=codexfleet1234
POSTGRES_DB=codexfleet
# Host the backend connects to. "postgres" = docker service name.
POSTGRES_HOST=postgres
# Host port mapped to postgres container (container always listens on 5432 internally).
POSTGRES_PORT=5432
