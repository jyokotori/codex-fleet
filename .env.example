# Set to "bundled-db" to use the included PostgreSQL container; leave empty to use an external DB
COMPOSE_PROFILES=bundled-db

# App
PORT=3000
CODEX_MASTER_KEY=change-me-in-production-use-32-chars-min

# Log level — examples:
#   backend=info,tower_http=info   (production)
#   backend=debug,tower_http=debug (verbose)
#   debug                          (everything)
RUST_LOG=backend=info,tower_http=info

# Bundled PostgreSQL credentials (only used when COMPOSE_PROFILES=bundled-db)
POSTGRES_USER=codexfleet
POSTGRES_PASSWORD=codexfleet
POSTGRES_DB=codexfleet

# Database URL — defaults to bundled postgres; override for an external DB
DATABASE_URL=postgres://codexfleet:codexfleet@postgres:5432/codexfleet
